# Copy this file to .env and update the values
# cp .env.example .env

# Required: where your projects live on your host
# Example on Windows: C:\Users\YourName\Documents
# Example on macOS/Linux: /home/yourname/projects
WORKSPACE_PATH=C:\Users\YourName\Documents

# Optional: git user name and email used inside the container
# If not set, defaults to "Dev User <dev@localhost>"
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com
